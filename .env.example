# Copy this file to .env and fill in your values.
# test_vllm.py reads these at runtime.

# Modal endpoint URL — printed by `modal deploy modal_vllm.py`
# Format: https://<workspace>--vllm-inference-serve.modal.run
MODAL_VLLM_URL=https://your-workspace--vllm-inference-serve.modal.run

# Must match the VLLM_API_KEY value stored in your Modal `vllm-auth` secret
VLLM_API_KEY=your-api-key-here

# Must match MODEL_ID at the top of modal_vllm.py
MODEL_ID=microsoft/Phi-3.5-mini-instruct

# HuggingFace token — only needed locally if downloading gated models.
# For Modal, store this in the `huggingface` secret instead (see README).
HF_TOKEN=hf_...
